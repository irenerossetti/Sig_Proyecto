# Django
SECRET_KEY=replace-me-with-a-secure-random-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geoguard

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Google Cloud APIs (Geocoding, Roads, Places)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Admin secret key for make-admin endpoint (CHANGE IN PRODUCTION!)
GEOGUARD_ADMIN_SECRET=change-this-secret-in-production

# Google Cloud Storage (optional, for photo uploads)
USE_GCS=False
GCS_BUCKET_NAME=geoguard-media
GCS_PROJECT_ID=your-gcp-project-id

# Firebase (for push notifications)
# FIREBASE_CREDENTIALS={"type":"service_account",...}

# Redis (for WebSocket channels in production)
# REDIS_URL=redis://localhost:6379
